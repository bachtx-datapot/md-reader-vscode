{
  "compilerOptions": {
    "target": "ES2021",
    "baseUrl": ".",
    "allowJs": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2021"],
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./extension",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/client/**/*"]
}
